rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }

    function isAdmin() {
      return isAuthed() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Server-side role / tool-grant checks so the SPA's client-side gating is
    // actually enforced (AUDIT security review 2026-06-18). All fail closed:
    // a caller with no users/{uid} doc is already denied access elsewhere.
    function userExists() {
      return isAuthed() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function roleIn(roles) {
      return userExists() && (userData().role in roles);
    }
    function hasTool(tool) {
      return userExists() && ('allowedTools' in userData()) && (tool in userData().allowedTools);
    }

    match /users/{uid} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Queue collection consumed by the processUserDeletion Cloud Function.
    // Admins write a request doc; the function processes it and cleans up.
    match /user-deletion-requests/{requestId} {
      allow create: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    && request.resource.data.requestedBy == request.auth.uid
                    && request.resource.data.targetUid != request.auth.uid;
      allow read, update, delete: if false;
    }

    // To-Do List (v1.61, collaborative) — full-trust model: any authed user
    // may read AND edit 'company'-visible tasks; private tasks are creator +
    // assignee only. Legacy docs predate the visibility/assigneeUid fields —
    // missing-field accesses error out and the || absorbs the error, so they
    // stay owner-only (the safe migration default; scripts/migrate-user-tasks.mjs
    // backfills). No hard deletes: the client soft-archives (a normal update).
    // ownerUid is immutable after create: with the creator pinned, the owner
    // read-disjunct always matches, so no edit (visibility flip, reassignment)
    // can ever lock the creator out of their own task.
    match /user-tasks/{taskId} {
      allow read: if isAuthed() && (
        resource.data.visibility == 'company'
        || request.auth.uid == resource.data.ownerUid
        || request.auth.uid == resource.data.assigneeUid
      );
      allow update: if isAuthed() && (
        resource.data.visibility == 'company'
        || request.auth.uid == resource.data.ownerUid
        || request.auth.uid == resource.data.assigneeUid
      ) && request.resource.data.ownerUid == resource.data.ownerUid;
      allow create: if isAuthed() && request.auth.uid == request.resource.data.ownerUid;
      allow delete: if false;
    }

    match /sites-registry/{id}        { allow read, write: if isAuthed(); }
    match /sites/{id}                 { allow read, write: if isAuthed(); }
    match /projects/{id}              { allow read, write: if isAuthed(); }
    match /siteRequests/{id}          { allow read, write: if isAuthed(); }
    // Leads carry decision-maker MOBILE PHONE PII — gate to admins + users
    // actually granted the Sales tool, not every authenticated employee (AUDIT).
    // assignedTo is immutable on client update (admin-only reassignment) so a rep
    // can't self-assign another rep's lead to reveal its phone (AUDIT M-7).
    match /leads/{id} {
      allow read, create, delete: if isAdmin() || hasTool('sales-crm');
      allow update: if isAdmin()
                    || (hasTool('sales-crm') && request.resource.data.assignedTo == resource.data.assignedTo);
    }
    // Lead Builder pipeline. Companies are written by Cloud Functions (Admin SDK,
    // bypasses these rules) for bulk stage transitions, AND by the admin-only
    // Lead Builder UI for per-row actions: Promote, Dismiss, inline Repair, and
    // Retry Apollo. Admin-gated, so only trusted admins can write — same posture
    // as the job docs below. Job docs are likewise admin-writable: the UI creates
    // a job (status:'ingesting', which triggers ingestCountyTaxRoll) and flips
    // status at the cost gates.
    match /lead-pipeline-companies/{id} { allow read, write: if isAdmin(); }
    match /lead-pipeline-jobs/{id}      { allow read, write: if isAdmin(); }
    // CRM is broadly readable by employees (cross-cutting directory) but writes
    // are restricted to roles that own CRM data — labor can't mutate (AUDIT).
    match /crm-companies/{id}         { allow read: if isAuthed(); allow write: if roleIn(['admin', 'manager', 'employee']); }
    match /crm-contacts/{id}          { allow read: if isAuthed(); allow write: if roleIn(['admin', 'manager', 'employee']); }
    match /crm-documents/{id}         { allow read: if isAuthed(); allow write: if roleIn(['admin', 'manager', 'employee']); }
    // Per-user history mirrored into the admin activity log — a user may only
    // create their OWN entries (no forging others) and read their own; admins
    // read all. No client updates/deletes (AUDIT: audit-log integrity).
    match /user-history/{id} {
      allow read:   if isAuthed() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /political-radar-federal-cache/{geohash} { allow read, write: if isAuthed(); }
    match /political-radar-tracked-bills/{id}      { allow read: if isAuthed(); allow write: if false; }
    match /political-radar-federal-officials/{id}  { allow read: if isAuthed(); allow write: if false; }
    match /political-radar-meta/{id}               { allow read: if isAuthed(); allow write: if false; }

    // Market Intelligence (data-center deal listener) — server-ingested by the
    // refreshMarketIntel Cloud Function (Admin SDK bypasses these rules). The
    // client reads the feed and toggles ONLY the status field (Mark read /
    // Archive); it cannot create or delete deals or edit ingested content.
    match /market-intel-feed/{id} {
      allow read:   if isAuthed();
      allow update: if isAuthed()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'updatedAt']);
      allow create, delete: if false;
    }
    match /market-intel-meta/{id} { allow read: if isAuthed(); allow write: if false; }

    match /folders/{id}            { allow read, write: if isAuthed(); }
    match /documents/{id}          { allow read, write: if isAuthed(); }
    match /customer-projects/{id}  { allow read, write: if isAuthed(); }

    // Construction Tracker (Bailey Project) — jobs gated by role + per-job membership.
    match /construction-jobs/{jobId} {

      function userRole() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }
      function jobDoc() {
        return get(/databases/$(database)/documents/construction-jobs/$(jobId)).data;
      }
      function hasJobAccess() {
        let role = userRole();
        return role == 'admin'
          || role == 'employee'
          || role == 'manager'
          || jobDoc().projectManagerId == request.auth.uid
          || request.auth.uid in jobDoc().workerIds;
      }
      function isAdminOrPm() {
        return userRole() == 'admin'
          || jobDoc().projectManagerId == request.auth.uid;
      }
      function isAdminOrEmployee() {
        let role = userRole();
        return role == 'admin' || role == 'employee' || role == 'manager';
      }

      allow read:   if isAuthed() && hasJobAccess();
      allow create: if isAuthed() && isAdminOrEmployee();
      allow update, delete: if isAuthed() && isAdminOrPm();

      match /tasks/{taskId} {
        allow read:   if isAuthed() && hasJobAccess();
        allow create: if isAuthed() && isAdminOrPm();
        allow delete: if isAuthed() && isAdminOrPm();
        allow update: if isAuthed() && (
          isAdminOrPm() ||
          (resource.data.assigneeId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'completedAt', 'updatedAt']))
        );
      }

      match /photos/{photoId} {
        allow read:   if isAuthed() && hasJobAccess();
        allow create: if isAuthed() && hasJobAccess()
                      && request.resource.data.uploadedBy == request.auth.uid;
        allow update, delete: if isAuthed() && (
                                isAdminOrPm() || resource.data.uploadedBy == request.auth.uid
                              );
      }

      // Legacy per-job document records — RETIRED 2026-06-19. The category-based
      // JobDocumentsSection UI, hook, and lib are deleted; the folder system
      // (top-level `documents` collection, above) is the only document surface.
      // These records were migrated into the folder system on 2026-05-14 and the
      // 30-day rollback window closed 2026-06-13, so client access is now
      // default-denied. Dormant docs remain in Firestore for an Admin-SDK purge.
      // NOTE: the Storage blobs at construction-documents/{jobId}/... are still
      // live — migrated folder-system records point at those exact paths — so
      // storage.rules deliberately keeps the construction-documents prefix.
    }

    match /preconstruction-sites/{siteId} {
      allow read, write: if request.auth != null;
    }

    // Construction Projects — fresh duplicate for the construction team.
    match /construction-projects-jobs/{jobId} {

      function userRoleCP() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }
      function jobDocCP() {
        return get(/databases/$(database)/documents/construction-projects-jobs/$(jobId)).data;
      }
      function hasJobAccessCP() {
        let role = userRoleCP();
        return role == 'admin'
          || role == 'employee'
          || role == 'manager'
          || jobDocCP().projectManagerId == request.auth.uid
          || request.auth.uid in jobDocCP().workerIds;
      }
      function isAdminOrPmCP() {
        return userRoleCP() == 'admin'
          || jobDocCP().projectManagerId == request.auth.uid;
      }
      function isAdminOrEmployeeCP() {
        let role = userRoleCP();
        return role == 'admin' || role == 'employee' || role == 'manager';
      }

      allow read:   if isAuthed() && hasJobAccessCP();
      allow create: if isAuthed() && isAdminOrEmployeeCP();
      allow update, delete: if isAuthed() && isAdminOrPmCP();

      match /tasks/{taskId} {
        allow read:   if isAuthed() && hasJobAccessCP();
        allow create: if isAuthed() && isAdminOrPmCP();
        allow delete: if isAuthed() && isAdminOrPmCP();
        allow update: if isAuthed() && (
          isAdminOrPmCP() ||
          (resource.data.assigneeId == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'completedAt', 'updatedAt']))
        );
      }

      match /photos/{photoId} {
        allow read:   if isAuthed() && hasJobAccessCP();
        allow create: if isAuthed() && hasJobAccessCP()
                      && request.resource.data.uploadedBy == request.auth.uid;
        allow update, delete: if isAuthed() && (
                                isAdminOrPmCP() || resource.data.uploadedBy == request.auth.uid
                              );
      }

      // Legacy per-job document records — RETIRED 2026-06-19. See the matching
      // note on construction-jobs above: the JobDocumentsSection UI is gone, the
      // folder system is the only document surface, the rollback window closed
      // 2026-06-13, and client access is now default-denied. Storage blobs at
      // construction-projects-documents/{jobId}/... stay live (migrated records
      // point at them), so storage.rules keeps that prefix.
    }

    match /infrastructure/{doc=**} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // Well Finder enrichment (Phase 2). Writes happen via the Cloud Run
    // service account using the Firestore Admin SDK, which bypasses these
    // rules — so no write rule is needed here.
    match /tx-wells-enriched/{api} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Well Finder status-change events (Phase 5). Writes are server-only
    // (the detectStatusChanges Cloud Function uses the Admin SDK).
    match /tx-well-changes/{eventId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Activity log — admin-only audit trail. Writes are server-only
    // (Cloud Functions activity triggers use the Admin SDK, which bypasses
    // these rules).
    match /activity/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    match /one-line-diagrams/{docId} {
      allow read, write: if request.auth != null;
    }

    match /substation_queue_load/{doc} { allow read: if isAuthed(); allow write: if false; }
    match /county_queue_load/{doc}     { allow read: if isAuthed(); allow write: if false; }
    match /iso_queue_projects/{doc}    { allow read: if isAuthed(); allow write: if false; }
    match /iso_queue_meta/{doc}        { allow read: if isAuthed(); allow write: if false; }
  }
}
