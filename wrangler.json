{
  "name": "randb-power-platform",
  "main": "functions/worker.ts",
  "compatibility_date": "2026-03-30",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "vars": {
    "FIREBASE_PROJECT_ID": "randb-site-valuator"
  },
  "unsafe": {
    "bindings": [
      {
        "name": "SITE_SCORE_RL",
        "type": "ratelimit",
        "namespace_id": "2001",
        "simple": { "limit": 30, "period": 60 }
      }
    ]
  }
}
